# Copia a .env en local. En Railway: Project → Variables (no subas .env al repo).

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Gmail con "Contraseñas de aplicación") ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Datos ─────────────────────────────────────────────────────────────────────
# Local: carpeta del proyecto. Railway: idealmente igual al mount del volumen (p. ej. /data).
# Si adjuntas un Volume en Railway, puedes omitir DATA_DIR y usar solo el mount del volumen
# (la app lee RAILWAY_VOLUME_MOUNT_PATH automáticamente).
DATA_DIR=./data

# ── Admin (para gestionar sesión OXXO Gas) ────────────────────────────────────
ADMIN_SECRET=

# ── Deploy (solo producción) ──────────────────────────────────────────────────
# URL pública HTTPS del servicio en Railway, sin barra final.
# Ej: https://cotas-production-xxxx.up.railway.app — con esto el bot usa webhook.
WEBHOOK_URL=
PORT=3000
NODE_ENV=development

# ── Opcional: proxy HTTP (7-Eleven, Petro 7 desde Railway, etc.) ─────────────
# IPs de datacenter suelen recibir 403; un proxy residencial MX evita el bloqueo.
# Formato: http://usuario:contraseña@host:puerto
# PROXY_URL_ROTATING=
# SEVENELEVEN_HTTP_PROXY=
#
# OXXO Gas (Playwright): con PROXY_URL_STICKY activo, NO usar proxy salvo que lo necesites.
# Si ves ERR_TUNNEL_CONNECTION_FAILED hacia facturacion.oxxogas.com, deja esto sin definir o en 0.
# Pon 1 en Railway Y en local (mismas PROXY_*) si el portal ató la sesión a IP MX: así save-session.js
# y facturarOxxoGas salen por el mismo proxy y /checkuser deja de fallar.
# OXXOGAS_USE_PLAYWRIGHT_PROXY=1
# Si ERR_TUNNEL con PROXY_URL_STICKY, define SOCKS (prioridad sobre HTTP para oxxogas):
# PROXY_URL_SOCKS5=socks5://usuario:pass@host:puerto
# Opcional: solo para OXXO Gas (sobrescribe orden)
# OXXOGAS_PROXY_URL=socks5://usuario:pass@host:puerto
