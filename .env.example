# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Gmail con "Contraseñas de aplicación") ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Datos ─────────────────────────────────────────────────────────────────────
# Local: carpeta del proyecto. Railway: idealmente igual al mount del volumen (p. ej. /data).
# Si adjuntas un Volume en Railway, también puedes omitir DATA_DIR y usar solo el mount del volumen
# (la app lee RAILWAY_VOLUME_MOUNT_PATH automáticamente).
DATA_DIR=./data

# ── Admin (para gestionar sesión OXXO Gas) ────────────────────────────────────
ADMIN_SECRET=

# ── Deploy (solo producción) ──────────────────────────────────────────────────
WEBHOOK_URL=
PORT=3000
NODE_ENV=development
